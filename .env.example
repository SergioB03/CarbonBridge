# Copy this file to ".env.local" and fill in any values you need.
# This is a frontend-only app — there is no backend and no secret keys are required to run it.

# VITE_COPILOT_URL (optional): URL of a Copilot chat backend.
# If unset, the in-app Copilot falls back to a built-in canned responder.
# VITE_COPILOT_URL=https://your-copilot-endpoint.example.com
